# ── Application ──────────────────────────────────────────────────────────────

# Server port (default: 5000)
PORT=5000

# Node environment: development | production | test
NODE_ENV=development

# ── Database ──────────────────────────────────────────────────────────────────

# MongoDB connection string
# Local: mongodb://127.0.0.1:27017/collab_code
# Atlas: mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/collab_code?retryWrites=true&w=majority
MONGO_URI=mongodb://127.0.0.1:27017/collab_code

# ── CORS ─────────────────────────────────────────────────────────────────────

# Frontend origin for CORS and Socket.io (no trailing slash)
CLIENT_ORIGIN=http://localhost:3000
